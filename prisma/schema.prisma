generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model LogDocumento {
  id           String   @id @default(uuid())
  tipo         String // "residencia" ou "residencia-responsabilidade"
  nomeArquivo  String
  dados        String   @default("{}") // JSON com os dados do documento
  criadoEm     DateTime @default(now())
  atualizadoEm DateTime @updatedAt

  @@index([tipo])
  @@index([criadoEm])
  @@map("logs_documentos")
}
